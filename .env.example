# Required for live /api/chat responses
OPENAI_API_KEY=sk-...

# App runtime
DEFAULT_MODEL=gpt-4.1-mini
NODE_ENV=development
PORT=3000
DOCKER=0

# Auth
AUTH_SECRET=nexbot_dev_secret
DEMO_EMAIL=demo@nexbot.io
DEMO_PASSWORD=demo1234
TOKEN_EXP_SECONDS=3600
ALLOW_REGISTRATION=true
REQUIRE_AUTH=false

# Rate limiting
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_WINDOW=20

# Database options
# For Docker Compose local Postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexbot
DATABASE_SSL=false

# For Supabase-hosted persistence and usage logging
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_KEY=
SUPABASE_ANON_KEY=
